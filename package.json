{
    "name": "rk-complete-care",
    "version": "1.0.0",
    "description": "RK The Complete Care - MERN Stack Project",
    "main": "index.js",
    "scripts": {
        "start": "node server/index.js",
        "build": "npm install && cd client && npm install && npm run build && cd ../server && npm install",
        "build:prod": "npm install && cd client && npm install && npm run build && cd ../server && npm install",
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "cd client && npm run dev",
        "dev:server": "cd server && npm run dev",
        "install:all": "concurrently \"npm run install:client\" \"npm run install:server\"",
        "install:client": "cd client && npm install",
        "install:server": "cd server && npm install"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "concurrently": "^8.2.2"
    },
    "devDependencies": {
        "nodemon": "^3.1.14"
    }
}